{
  "name": "tcc",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "transform-to-ts": "ts-node apps/web/scripts/transform-to-typescript.ts"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "prettier": "^3.5.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@mui/lab": "^6.0.0-beta.28",
    "@mui/x-date-pickers": "^7.27.0",
    "glob": "^11.0.1",
    "tss-react": "^4.9.15"
  }
}
