{
  "name": "@tcc/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:test": "NODE_ENV=test tsx watch src/test-server.ts",
    "migration:gen": "drizzle-kit generate",
    "migration:run": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "test": "vitest --run",
    "seed": "tsx scripts/seed.ts",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "main": "shared/index.ts",
  "module": "shared/index.ts",
  "types": "shared/index.ts",
  "license": "MIT",
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@hono/node-server": "^1.14.0",
    "@tcc/tests": "*",
    "@types/express": "^5.0.3",
    "@types/nodemailer": "^6.4.17",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.41.0",
    "drizzle-zod": "^0.7.1",
    "express": "^5.1.0",
    "hono": "^4.2.4",
    "nodemailer": "^7.0.5",
    "pg": "^8.14.1",
    "ts-pattern": "^5.7.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.2",
    "vitest": "^1.5.0",
    "wrangler": "^3.53.0"
  }
}
